# FlowDesk Environment Variables
# Copy this file to .env and fill in your values.

# ─── Telegram Bot ──────────────────────────────────────────────
# Get your token from @BotFather on Telegram (see README for steps).
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz_example

# Your public HTTPS URL where Telegram sends webhook updates.
# Must be HTTPS. Use ngrok/cloudflared for local dev.
# Example: https://your-subdomain.ngrok-free.app
# Leave empty to skip automatic webhook registration on startup.
TELEGRAM_WEBHOOK_URL=https://your-subdomain.ngrok-free.app

# ─── LLM Provider ─────────────────────────────────────────────
# gemini | openai | ollama
LLM_PROVIDER=gemini

# API key for Gemini/OpenAI. Leave empty for Ollama.
LLM_API_KEY=AQ.<gemini_key>

# Examples: gemini-2.0-flash, gpt-4.1-mini, llama3
LLM_MODEL=gemini-2.0-flash

# Only used when LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120

# ─── Admin ────────────────────────────────────────────────────
ADMIN_KEY=replace-with-a-long-random-admin-key

# ─── Google OAuth for Telegram /link ──────────────────────────
# These values come from Google Cloud Console OAuth Client.
# The redirect URI must be registered in Google exactly as written here.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-api-domain.example.com/auth/google/callback

# Optional comma-separated domains. Leave empty to allow any verified Google account.
# Examples if you want to restrict later: .edu,iiits.ac.in,iitb.ac.in
# LEAVE EMPTY RIGHT NOW
ALLOWED_EMAIL_DOMAINS=

# ─── Database ─────────────────────────────────────────────────
# SQLite database path (relative to project root)
DATABASE_PATH=data/flowdesk.db
