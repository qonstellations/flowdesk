# FlowDesk Environment Variables
# Copy this file to .env and fill in your values.

# ─── Telegram Bot ──────────────────────────────────────────────
# Get your token from @BotFather on Telegram (see README for steps).
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz_example

# Your public HTTPS URL where Telegram sends webhook updates.
# Must be HTTPS. Use ngrok/cloudflared for local dev.
# Example: https://your-subdomain.ngrok-free.app
# Leave empty to skip automatic webhook registration on startup.
TELEGRAM_WEBHOOK_URL=https://your-subdomain.ngrok-free.app

# ─── LLM Provider ─────────────────────────────────────────────
# API key for your LLM provider (Gemini, OpenAI, etc.)
LLM_API_KEY=AQ.Ab8RN6Kw2Xi4_HaMTyf2euR8ktiw9WIRoJOoT2jRRJwLjemoPQ

# Model to use for complaint classification
# Examples: gemini-2.0-flash, gpt-4o-mini
LLM_MODEL=gemini-2.0-flash

# ─── Database ─────────────────────────────────────────────────
# SQLite database path (relative to project root)
DATABASE_PATH=data/flowdesk.db
