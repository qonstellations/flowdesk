# FlowDesk Environment Variables

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Webhook URL (your public URL for receiving updates)
TELEGRAM_WEBHOOK_URL=

# LLM Provider API Key
LLM_API_KEY=

# LLM Model Name (e.g., gemini-2.0-flash, gpt-4o-mini)
LLM_MODEL=

# Database Path (default: data/flowdesk.db)
DATABASE_PATH=data/flowdesk.db
